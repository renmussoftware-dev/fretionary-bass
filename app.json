{
  "expo": {
    "name": "Fretionary Bass",
    "slug": "fretionary-bass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renmussoftware.fretionarybass",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [],
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "KHWB32323Q"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.renmussoftware.fretionarybass",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "permissions": [],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "PLACEHOLDER_META_APP_ID",
          "clientToken": "PLACEHOLDER_META_CLIENT_TOKEN",
          "displayName": "Fretionary Bass",
          "scheme": "fbPLACEHOLDER_META_APP_ID",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true,
          "isAutoInitEnabled": true,
          "iosUserTrackingPermission": "Allow Fretionary Bass to use your activity to help us improve and personalize ads. This helps keep the app free and the Pro tier affordable."
        }
      ]
    ],
    "scheme": "fretionarybass",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
