{
  "expo": {
    "name": "Fretionary Bass",
    "slug": "fretionary-bass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renmussoftware.fretionarybass",
      "buildNumber": "3",
      "infoPlist": {
        "UIBackgroundModes": [],
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Allow Fretionary Bass to use your activity to help us improve and personalize ads. This helps keep the app free and the Pro tier affordable.",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          }
        ]
      },
      "appleTeamId": "KHWB32323Q"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.renmussoftware.fretionarybass",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "scheme": "fretionarybass",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "95aea364-4dd4-46b8-ae3a-909d8c352599"
      },
      "_note_fbsdk": "Meta SDK (react-native-fbsdk-next) plugin intentionally omitted until a real Meta app is provisioned. Re-add the plugin block with the real appID + clientToken — the generated fb<appID> URL scheme must be valid, App Store rejects placeholder schemes (ITMS-90158)."
    },
    "owner": "renmussoftware"
  }
}
